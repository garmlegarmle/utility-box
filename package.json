    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "concurrently": "^9.2.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.3"
  }
